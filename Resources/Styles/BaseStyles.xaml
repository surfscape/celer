<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                    xmlns:theme="clr-namespace:Microsoft.Windows.Themes;assembly=PresentationFramework.Aero2"
                    xmlns:local="clr-namespace:Celer.Utilities">
    <Style x:Key="FocusMenu">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border CornerRadius="4"
                            BorderBrush="{DynamicResource FocusStrokeColorOuterBrush}"
                            BorderThickness="1">
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="{x:Type ContentControl}">
        <Setter Property="Focusable"
                Value="False"></Setter>
    </Style>
    <Style TargetType="{x:Type TextBlock}"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize"
                Value="15" />
    </Style>
    <Style x:Key="Heading1"
           BasedOn="{StaticResource {x:Type TextBlock}}"
           TargetType="{x:Type TextBlock}">
        <Setter Property="Control.FontSize"
                Value="28" />
        <Setter Property="Control.FontWeight"
                Value="DemiBold" />
        <Setter Property="Margin"
                Value="0,0,0,8" />
        <Setter Property="Foreground"
                Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="Heading2"
           BasedOn="{StaticResource {x:Type TextBlock}}"
           TargetType="{x:Type TextBlock}">
        <Setter Property="Control.FontSize"
                Value="18" />
        <Setter Property="Control.FontWeight"
                Value="DemiBold" />
        <Setter Property="Margin"
                Value="0,0,0,6" />
        <Setter Property="Foreground"
                Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="Subheading"
           BasedOn="{StaticResource {x:Type TextBlock}}"
           TargetType="{x:Type TextBlock}">
        <Setter Property="Control.FontSize"
                Value="16" />
        <Setter Property="Foreground"
                Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>
    <Style x:Key="HeadingIcon"
           TargetType="{x:Type iconPacks:PackIconLucide}">
        <Setter Property="SnapsToDevicePixels"
                Value="True" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type TextBlock}}, Path=Name}"
                         Value="Heading2">
                <Setter Property="Width"
                        Value="20" />
                <Setter Property="Height"
                        Value="20" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="CelerStripTabLeft"
           TargetType="TabControl">
        <Setter Property="TabStripPlacement"
                Value="Left" />
        <Setter Property="Padding"
                Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"></RowDefinition>
                        </Grid.RowDefinitions>
                        <TabPanel Grid.Column="0"
                                  Margin="4,6,4,4"
                                  Background="Transparent"
                                  IsItemsHost="True" />
                        <Border Grid.Column="1"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                Background="{DynamicResource LayerFillColorDefaultBrush}"
                                BorderThickness="1,1,0,0"
                                CornerRadius="8,0,0,0"
                                Padding="0,0,4,4">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          Focusable="False"
                                          
                                          VerticalScrollBarVisibility="{Binding SelectedContent.VerticalScrollMode, RelativeSource={RelativeSource TemplatedParent}}">
                                <ContentPresenter x:Name="Content"
                                                  Margin="16,16,16,0"
                                                  MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=local:CompactTabControl}, Path=UserContentSize}"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Top"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  Content="{TemplateBinding SelectedContent}"
                                                  ContentTemplate="{TemplateBinding SelectedContentTemplate}" />
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="TabItem">
                    <Setter Property="Header"
                            Value="{Binding}" />
                    <Setter Property="Padding"
                            Value="0"></Setter>
                    <Setter Property="Background"
                            Value="Transparent" />
                    <Setter Property="FocusVisualStyle"
                            Value="{DynamicResource FocusMenu}"></Setter>
                    <Setter Property="HeaderTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <Border Padding="13,0,0,0"
                                        Height="36"
                                        ToolTip="{Binding Title}">
                                    <StackPanel Orientation="Horizontal"
                                                Background="Transparent"
                                                MinWidth="172"
                                                x:Name="Wrap">
                                        <iconPacks:PackIconLucide x:Name="Icon"
                                                                  Kind="{Binding Icon}"
                                                                  Margin="0,0,13,0"
                                                                  VerticalAlignment="Center"
                                                                  SnapsToDevicePixels="True"
                                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                  Visibility="Visible" />
                                        <TextBlock x:Name="Text"
                                                   Text="{Binding Title}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Visibility="Visible" />
                                    </StackPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=local:CompactTabControl}, Path=CompactMode}"
                                                 Value="True">
                                        <Setter TargetName="Text"
                                                Property="Visibility"
                                                Value="Collapsed" />
                                        <Setter TargetName="Wrap"
                                                Property="MinWidth"
                                                Value="0"></Setter>
                                        <Setter TargetName="Wrap"
                                                Property="Width"
                                                Value="auto"></Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=local:CompactTabControl}, Path=CompactMode}"
                                                 Value="false">
                                        <Setter TargetName="Text"
                                                Property="Visibility"
                                                Value="Visible" />
                                        <Setter TargetName="Wrap"
                                                Property="MinWidth"
                                                Value="172"></Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=IsSelected}"
                                                 Value="True">
                                        <Setter TargetName="Icon"
                                                Property="Foreground"
                                                Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        <Setter TargetName="Text"
                                                Property="Foreground"
                                                Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=IsMouseOver}"
                                                       Value="True" />
                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=IsSelected}"
                                                       Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="Icon"
                                                Property="Foreground"
                                                Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        <Setter TargetName="Text"
                                                Property="Foreground"
                                                Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Grid>
                                    <Border x:Name="HeaderActive"
                                            HorizontalAlignment="Left"
                                            Width="3"
                                            Height="16"
                                            Panel.ZIndex="2"
                                            CornerRadius="3" />
                                    <Border x:Name="HeaderBorder"
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Margin="0,2,0,2">
                                        <ContentPresenter x:Name="Content"
                                                          HorizontalAlignment="Stretch"
                                                          VerticalAlignment="Center"
                                                          ContentSource="Header"
                                                          RecognizesAccessKey="True" />
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger SourceName="HeaderBorder"
                                             Property="IsMouseOver"
                                             Value="True">
                                        <Setter TargetName="HeaderBorder"
                                                Property="Background"
                                                Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected"
                                             Value="True">
                                        <Setter TargetName="HeaderBorder"
                                                Property="Background"
                                                Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                        <Setter TargetName="HeaderActive"
                                                Property="Background"
                                                Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>
    <Style BasedOn="{StaticResource {x:Type ListBox}}"
           TargetType="{x:Type ListBox}">
        <Setter Property="BorderBrush"
                Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="Background"
                Value="Transparent" />
    </Style>
    <Style TargetType="Hyperlink">
        <Setter Property="Foreground"
                Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="ModuleButton"
           BasedOn="{StaticResource {x:Type Button}}"
           TargetType="{x:Type Button}">
        <Setter Property="Margin"
                Value="10,10,0,0" />
        <Setter Property="Padding"
                Value="16" />
        <Setter Property="HorizontalContentAlignment"
                Value="Left" />
        <Setter Property="VerticalContentAlignment"
                Value="Top" />
        <Setter Property="HorizontalAlignment"
                Value="Stretch" />
        <Setter Property="VerticalAlignment"
                Value="Stretch" />
        <Setter Property="local:ButtonHelper.CornerRadius"
                Value="6"></Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ButtonBase}">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding local:ButtonHelper.CornerRadius}">
                        <ContentPresenter x:Name="contentPresenter"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Focusable="False"
                                          RecognizesAccessKey="True"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Button.IsDefaulted"
                                 Value="true">
                            <Setter TargetName="border"
                                    Property="BorderBrush"
                                    Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver"
                                 Value="true">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed"
                                 Value="true">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="{DynamicResource  SubtleFillColorTertiaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled"
                                 Value="false">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="Transparent" />
                            <Setter TargetName="border"
                                    Property="BorderBrush"
                                    Value="Transparent" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="TransparentButton"
           BasedOn="{StaticResource {x:Type Button}}"
           TargetType="{x:Type Button}">
        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="BorderBrush"
                Value="Transparent" />
        <Setter Property="Foreground"
                Value="white" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="HorizontalContentAlignment"
                Value="Center" />
        <Setter Property="VerticalContentAlignment"
                Value="Center" />
        <Setter Property="Padding"
                Value="10,5" />
        <Setter Property="local:ButtonHelper.CornerRadius"
                Value="4" />
        <Setter Property="local:ButtonHelper.BackgroundHover"
                Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ButtonBase}">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding local:ButtonHelper.CornerRadius}">
                        <ContentPresenter x:Name="contentPresenter"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Focusable="False"
                                          RecognizesAccessKey="True"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Button.IsDefaulted"
                                 Value="true">
                            <Setter TargetName="border"
                                    Property="BorderBrush"
                                    Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver"
                                 Value="true">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="{Binding Path=(local:ButtonHelper.BackgroundHover), 
                 RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger Property="IsPressed"
                                 Value="true">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="{DynamicResource  SubtleFillColorTertiaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled"
                                 Value="false">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="Transparent" />
                            <Setter TargetName="border"
                                    Property="BorderBrush"
                                    Value="Transparent" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>