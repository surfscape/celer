<UserControl
    x:Class="Celer.Controls.SettingCategoryButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:Celer.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sg="clr-namespace:SpacedGridControl;assembly=SpacedGridControl"
    x:Name="root"
    d:DataContext="{d:DesignInstance Type=local:SettingCategoryButton}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Button
        Padding="16,12"
        Margin="3"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
        Command="{Binding Path=Command, RelativeSource={RelativeSource AncestorType=UserControl}}"
        CommandParameter="{Binding CommandParameter, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <iconPacks:PackIconLucide
                Grid.Column="0"
                Width="20"
                Height="20"
                Margin="0,0,16,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Kind="{Binding Icon, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            <StackPanel Grid.Column="1">
                <TextBlock
                    Margin="0,0,0,2"
                    Style="{DynamicResource BodyStrongTextBlockStyle}"
                    Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <TextBlock
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Style="{DynamicResource BodyTextBlockStyle}"
                    Text="{Binding Description, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </StackPanel>
            <TextBlock
                Grid.Column="2"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Text="&#xE76C;" />
        </Grid>
    </Button>
</UserControl>
