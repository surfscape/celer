<UserControl x:Class="Celer.Controls.SettingCategoryButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Celer.Controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:sg="clr-namespace:SpacedGridControl;assembly=SpacedGridControl"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=local:SettingCategoryButton}"
             x:Name="root">
    <Button HorizontalAlignment="Stretch"
            Padding="16,12"
            HorizontalContentAlignment="Stretch"
            Command="{Binding Path=Command, RelativeSource={RelativeSource AncestorType=UserControl}}"
            CommandParameter="{Binding CommandParameter, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <sg:SpacedGrid ColumnDefinitions="auto * auto"
                       ColumnSpacing="12">
            <iconPacks:PackIconLucide Width="16"
                                      Height="16"
                                      Margin="0"
                                      VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Kind="{Binding Icon, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            <StackPanel Grid.Column="1">
                <TextBlock Style="{DynamicResource BodyStrongTextBlockStyle}"
                           Margin="0,0,0,2"
                           Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"></TextBlock>
                <TextBlock Style="{DynamicResource BodyTextBlockStyle}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding Description, RelativeSource={RelativeSource AncestorType=UserControl}}"></TextBlock>
            </StackPanel>
            <iconPacks:PackIconLucide Width="13"
                                      Height="13"
                                      Margin="0"
                                      Grid.Column="2"
                                      VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Kind="ChevronRight" />
        </sg:SpacedGrid>
    </Button>
</UserControl>
