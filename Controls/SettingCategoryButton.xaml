<UserControl x:Class="Celer.Controls.SettingCategoryButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Celer.Controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:sg="clr-namespace:SpacedGridControl;assembly=SpacedGridControl"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=local:SettingCategoryButton}"
             x:Name="root">
    <Button HorizontalAlignment="Stretch"
            Padding="16,12"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            HorizontalContentAlignment="Stretch"
            Command="{Binding Path=Command, RelativeSource={RelativeSource AncestorType=UserControl}}"
            CommandParameter="{Binding CommandParameter, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <Grid >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <iconPacks:PackIconLucide Width="16"
                                      Height="16"
                                      Margin="0,0,16,0"
                                      Grid.Column="0"
                                      VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Kind="{Binding Icon, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            <StackPanel Grid.Column="1">
                <TextBlock Style="{DynamicResource BodyStrongTextBlockStyle}"
                           Margin="0,0,0,2"
                           Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <TextBlock Style="{DynamicResource BodyTextBlockStyle}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding Description, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </StackPanel>
            <TextBlock Text="&#xE76C;"
                           Grid.Column="2"
                       VerticalAlignment="Center"
                           FontFamily="Segoe Fluent Icons"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            
        </Grid>
    </Button>
</UserControl>
