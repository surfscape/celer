<Window
    x:Class="Celer.Views.Windows.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Celer.Views.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="About"
    ResizeMode="NoResize"
    SizeToContent="WidthAndHeight"
    Style="{StaticResource {x:Type Window}}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Border Padding="16">
        <StackPanel>
            <Image
                Width="156"
                Height="156"
                Source="/Resources/Assets/celer_256.png" />
            <TextBlock
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Style="{StaticResource TitleLargeTextBlockStyle}"
                TextAlignment="Center">
                Celer
            </TextBlock>
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,4,0"
                    FontSize="14"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    Version:
                </TextBlock>
                <TextBlock
                    Name="Version"
                    FontSize="14"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    TextAlignment="Center" />
            </StackPanel>
            <StackPanel Margin="0,16,0,0" HorizontalAlignment="Center">
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="14"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    TextAlignment="Center">
                    Special thanks to:
                </TextBlock>
                <TextBlock FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}"><Hyperlink NavigateUri="https://surfscape.eu/" RequestNavigate="Hyperlink_RequestNavigate">Flixin</Hyperlink>
                    for feedback and testing</TextBlock>
            </StackPanel>
            <WrapPanel Margin="0,12,0,0">
                <WrapPanel.Resources>
                    <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
                        <Setter Property="Margin" Value="0,0,16,0" />
                    </Style>
                </WrapPanel.Resources>
                <TextBlock><Hyperlink NavigateUri="https://surfscape.eu/" RequestNavigate="Hyperlink_RequestNavigate">SurfScape Website</Hyperlink></TextBlock>
                <TextBlock><Hyperlink NavigateUri="https://surfscape.eu/projects/celer" RequestNavigate="Hyperlink_RequestNavigate">Celer Homepage</Hyperlink></TextBlock>
                <TextBlock Margin="0"><Hyperlink NavigateUri="https://surfscape.eu/community/" RequestNavigate="Hyperlink_RequestNavigate">Support</Hyperlink></TextBlock>
            </WrapPanel>
            <TextBlock
                Margin="0,16,0,0"
                FontSize="13"
                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                TextAlignment="Center">
                ©️ 2026 SurfScape and contributors
            </TextBlock>
        </StackPanel>
    </Border>
</Window>
