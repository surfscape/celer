<Window
    x:Class="Celer.Views.Windows.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Celer.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helper="clr-namespace:Celer.Utilities"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:Celer.Views.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:Celer.Models"
    xmlns:pages="clr-namespace:Celer.Views.Pages.Settings"
    xmlns:uc="clr-namespace:Celer.Controls"
    xmlns:vm="clr-namespace:Celer.ViewModels"
    Title="Preferences"
    Width="860"
    Height="550"
    MinWidth="860"
    MinHeight="500"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ShowInTaskbar="True"
    Style="{StaticResource {x:Type Window}}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Window.Resources>
        <converters:NullableBoolToBoolConverter x:Key="NullableBoolToBoolConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </Window.Resources>
    <Border
        x:Name="HighContrastBorder"
        Padding="3,0,0,0"
        BorderBrush="Transparent"
        BorderThickness="8,1,8,8">
        <Grid x:Name="MainGrid" RowDefinitions="auto *">
            <!--  Titlebar  -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!--  Navigation controls  -->
                    <StackPanel
                        Grid.Column="0"
                        Margin="4,5,0,0"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                        <Button
                            Margin="2,0,0,0"
                            Padding="14,11"
                            Command="{Binding GoBackCommand}"
                            Style="{DynamicResource TransparentButton}"
                            ToolTip="Go back to the previous screen"
                            WindowChrome.IsHitTestVisibleInChrome="True">

                            <iconPacks:PackIconLucide
                                Width="13"
                                Height="13"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Kind="ArrowLeft" />
                        </Button>
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        AutomationProperties.HeadingLevel="Level1"
                        FontSize="18"
                        LineHeight="10pt"
                        LineStackingStrategy="BlockLineHeight"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="{Binding CurrentViewTitle}" />
                    <Border
                        Grid.Column="2"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0" />
                    <UniformGrid
                        Grid.Column="3"
                        VerticalAlignment="Top"
                        Columns="3">
                        <Button
                            x:Name="MinimizeButton"
                            Padding="18,12"
                            helper:ButtonHelper.CornerRadius="0"
                            Click="MinimizeButton_Click"
                            Focusable="False"
                            Style="{DynamicResource TransparentButton}">
                            <TextBlock
                                FontFamily="Segoe Fluent Icons"
                                FontSize="10"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="&#xE921;" />
                        </Button>
                        <Button
                            x:Name="MaximizeButton"
                            Padding="18,12"
                            helper:ButtonHelper.CornerRadius="0"
                            Click="RestoreOrMaximizeButton_Click"
                            Focusable="False"
                            IsEnabled="{Binding IsEnabled, ElementName=MaximizeButton}"
                            Style="{DynamicResource TransparentButton}">
                            <TextBlock
                                FontFamily="Segoe Fluent Icons"
                                FontSize="10"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="&#xE922;" />
                        </Button>
                        <Button
                            x:Name="CloseButton"
                            Padding="18,12"
                            helper:ButtonHelper.BackgroundHover="#C42B1C"
                            helper:ButtonHelper.CornerRadius="0"
                            Click="CloseButton_Click"
                            Focusable="False"
                            Style="{DynamicResource TransparentButton}">
                            <TextBlock
                                FontFamily="Segoe Fluent Icons"
                                FontSize="10"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="&#xE8BB;" />
                        </Button>
                    </UniformGrid>
                </Grid>
            </Grid>
            <Border
                Grid.Row="1"
                MaxWidth="980"
                Padding="16">
                <Grid>
                    <ScrollViewer Focusable="False" VerticalScrollBarVisibility="Auto">
                        <ContentControl Content="{Binding CurrentViewModel}">
                            <ContentControl.Resources>
                                <DataTemplate DataType="{x:Type pages:SettingsShellViewModel}">
                                    <pages:SettingsShell Margin="-4" />
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type pages:SettingsGeneralViewModel}">
                                    <pages:SettingsGeneral />
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type pages:SettingsInterfaceViewModel}">
                                    <pages:SettingsInterface />
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type pages:SettingsAdvancedViewModel}">
                                    <pages:SettingsAdvanced />
                                </DataTemplate>
                            </ContentControl.Resources>
                        </ContentControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>