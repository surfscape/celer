<controlzEx:WindowChromeWindow xmlns:controlzEx="urn:controlzex"
                               x:Class="Celer.Views.Windows.MainWindow"
                               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                               xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                               xmlns:model="clr-namespace:Celer.Models"
                               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                               xmlns:uc="clr-namespace:Celer.Views.UserControls.MainApp"
                               xmlns:viewmodels="clr-namespace:Celer.ViewModels"
                               Title="Celer"
                               MinWidth="940"
                               MinHeight="640"
                               Width="940"
                               Height="640"
                               xmlns:tb="http://www.hardcodet.net/taskbar"
                               WindowStartupLocation="CenterScreen"
                               xmlns:local="clr-namespace:Celer.Utilities"
                               xmlns:mainwindow="clr-namespace:Celer.Views.UserControls.MainWindow"
                               xmlns:converters="clr-namespace:Celer.Converters"
                               PreferDWMBorderColor="True"
                               GlowColor="#424242"
                               NonActiveGlowColor="#424242"
                               d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
                               d:Background="white"
                               controlzEx:WindowBackdropManager.BackdropType="Mica"
                               mc:Ignorable="d">
    <controlzEx:WindowChromeWindow.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </controlzEx:WindowChromeWindow.Resources>
    <Border BorderThickness="0"
            CornerRadius="6"
            Margin="0"
            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
            x:Name="WindowBorder">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <!-- Titlebar -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- Navigation controls -->
                    <StackPanel Grid.Column="0"
                                Margin="4,4,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Button Padding="14,11"
                                Style="{DynamicResource TransparentButton}"
                                Command="{Binding ToggleCompactModeCommand}">
                            <iconPacks:PackIconLucide Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                      Kind="Menu"
                                                      Width="13"
                                                      Height="13" />
                        </Button>
                        <Button ToolTip="Go back to the previous screen"
                                Margin="2,0,0,0"
                                Style="{DynamicResource TransparentButton}"
                                Padding="14,11"
                                IsEnabled="{Binding CanGoBack}"
                                Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding GoBackCommand}">

                            <iconPacks:PackIconLucide Width="13"
                                                      Height="13"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      Kind="ArrowLeft" />
                        </Button>
                    </StackPanel>
                    <Image Margin="12,0,0,0"
                           Width="16"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           controlzEx:WindowChrome.IsHitTestVisibleInChrome="False"
                           controlzEx:NonClientControlProperties.HitTestResult="CAPTION"
                           Source="/celer_icon.ico"></Image>
                    <TextBlock Grid.Column="3"
                               Margin="12 0 18 0"
                               FontSize="13"
                               VerticalAlignment="Center"
                               controlzEx:WindowChrome.IsHitTestVisibleInChrome="False"
                               controlzEx:NonClientControlProperties.HitTestResult="CAPTION"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Text="Celer Beta" />
                    <Rectangle Width="1"
                               Height="24"
                               Margin="0,1,8,0"
                               Grid.Column="4"
                               Fill="{DynamicResource SurfaceStrokeColorDefaultBrush}"></Rectangle>
                    <ContentControl Content="{Binding MenuBarControl}"
                                    Focusable="False"
                                    VerticalAlignment="Center"
                                    Grid.Column="5" />
                    <Border Grid.Column="6"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            controlzEx:WindowChrome.IsHitTestVisibleInChrome="False"
                            controlzEx:NonClientControlProperties.HitTestResult="CAPTION"
                            BorderThickness="0"
                            Width="{Binding ElementName=Window, Path=CaptionButtonsSize.Width}"
                            Height="{Binding ElementName=Window, Path=CaptionButtonsSize.Height}" />

                    <UniformGrid Grid.Column="7"
                                 Columns="3"
                                 VerticalAlignment="Top">
                        <Button Padding="18,12"
                                Style="{DynamicResource TransparentButton}"
                                Click="MinimizeButton_Click"
                                Focusable="False"
                                local:ButtonHelper.CornerRadius="0"
                                controlzEx:NonClientControlProperties.ClickStrategy="AutomationPeer">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Text="&#xE921;"></TextBlock>
                        </Button>
                        <Button IsEnabled="{Binding IsEnabled, ElementName=MaximizeButton}"
                                Style="{DynamicResource TransparentButton}"
                                Click="RestoreOrMaximizeButton_Click"
                                Padding="18,12"
                                Focusable="False"
                                local:ButtonHelper.CornerRadius="0"
                                controlzEx:NonClientControlProperties.ClickStrategy="MouseEvent">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Text="&#xE922;"></TextBlock>
                        </Button>
                        <Button Style="{DynamicResource TransparentButton}"
                                Click="CloseButton_Click"
                                Padding="18,12"
                                Focusable="False"
                                local:ButtonHelper.BackgroundHover="#C42B1C"
                                local:ButtonHelper.CornerRadius="0"
                                controlzEx:NonClientControlProperties.ClickStrategy="MouseEvent">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Text="&#xE8BB;"></TextBlock>
                        </Button>
                    </UniformGrid>
                </Grid>
            </Grid>
            <!-- Main content -->
            <Border Grid.Row="1">
                <Grid>
                    <local:CompactTabControl  SelectedIndex="{Binding SelectedTabIndex}"
                                              CompactMode="{Binding TabControlCompactMode, Mode=TwoWay}"
                                              Style="{StaticResource CelerStripTabLeft}">
                        <local:CompactTabControl.Resources>
                            <Style TargetType="{x:Type iconPacks:PackIconLucide}">
                                <Setter Property="Width"
                                        Value="15" />
                                <Setter Property="Height"
                                        Value="15" />

                            </Style>
                        </local:CompactTabControl.Resources>
                        <TabItem>
                            <TabItem.Header>
                                <model:TabHeaderData Title="Dashboard"
                                                     Icon="Activity" />
                            </TabItem.Header>
                            <ContentControl HorizontalAlignment="Stretch"
                                            Content="{Binding DashboardControl}" />
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <model:TabHeaderData Title="Cleaning"
                                                     Icon="Trash" />
                            </TabItem.Header>
                            <ContentControl HorizontalAlignment="Stretch"
                                            Content="{Binding LimpezaControl}" />
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <model:TabHeaderData Title="Optimization"
                                                     Icon="Rocket" />
                            </TabItem.Header>
                            <ContentControl HorizontalAlignment="Stretch"
                                            Content="{Binding OptimizationControl}" />
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <model:TabHeaderData Title="Maintenance"
                                                     Icon="Construction" />
                            </TabItem.Header>
                            <ContentControl HorizontalAlignment="Stretch"
                                            Content="{Binding MaintenanceControl}" />
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <model:TabHeaderData Title="Privacy &amp; Security"
                                                     Icon="Shield" />
                            </TabItem.Header>
                            <uc:Privacidade HorizontalAlignment="Stretch" />
                        </TabItem>
                    </local:CompactTabControl>
                </Grid>
            </Border>
            <!-- Quick Center -->
            <tb:TaskbarIcon IconSource="/celer_icon.ico"
                            ToolTipText="Celer"
                            d:DataContext="{d:DesignInstance Type=viewmodels:QCMenuViewModel}">
                <tb:TaskbarIcon.TrayPopup>
                    <mainwindow:QuickCenter></mainwindow:QuickCenter>
                </tb:TaskbarIcon.TrayPopup>
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu x:Name="QCMenu">
                        <MenuItem Header="Open"
                                  Command="{Binding QCOpenAppCommand}" />
                        <MenuItem Header="Exit"
                                  Command="{Binding QCExitAppCommand}" />
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
        </Grid>
    </Border>
</controlzEx:WindowChromeWindow>

