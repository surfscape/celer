<Window 
                               x:Class="Celer.Views.Windows.MainWindow"
                               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                               xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                               xmlns:model="clr-namespace:Celer.Models"
                               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                               xmlns:uc="clr-namespace:Celer.Views.UserControls.MainApp"
                               xmlns:viewmodels="clr-namespace:Celer.ViewModels"
                               Title="Celer"
                               MinWidth="940"
                               MinHeight="640"
                               Width="940"
                               Height="640"
                               xmlns:tb="http://www.hardcodet.net/taskbar"
                               WindowStartupLocation="CenterScreen"
                               xmlns:local="clr-namespace:Celer.Utilities"
                               xmlns:mainwindow="clr-namespace:Celer.Views.UserControls.MainWindow"
                               xmlns:converters="clr-namespace:Celer.Converters"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"

                               d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
                               d:Background="white"
                               mc:Ignorable="d">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:MenuStateToolTipConverter x:Key="MenuStateToolTipConverter" />
    </Window.Resources>
    <Border x:Name="HighContrastBorder"
            BorderBrush="Transparent"
            Padding="3,0,0,0"
            BorderThickness="8 1 8 8">
        <Grid x:Name="MainGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <!-- Titlebar -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- Navigation controls -->
                    <StackPanel Grid.Column="0"
                                Margin="4,4,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Button Padding="14,12"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{DynamicResource TransparentButton}"
                                ToolTip="{Binding TabControlCompactMode, Converter={StaticResource MenuStateToolTipConverter}}"
                                Command="{Binding ToggleCompactModeCommand}">
                            <iconPacks:PackIconLucide Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                      Kind="Menu"
                                                      Width="13"
                                                      Height="13" />
                        </Button>
                        <Button ToolTip="Go back to the previous screen"
                                Margin="4,0,0,0"
                                Style="{DynamicResource TransparentButton}"
                                Padding="14,11"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                IsEnabled="{Binding CanGoBack}"
                                Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding GoBackCommand}">

                            <iconPacks:PackIconLucide Width="13"
                                                      Height="13"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      Kind="ArrowLeft" />
                        </Button>
                    </StackPanel>
                    <Image Margin="8,0,0,0"
                           Width="20"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Source="/celer_icon.ico"></Image>
                    <TextBlock Grid.Column="2"
                               Margin="12 0 18 0"
                               AutomationProperties.HeadingLevel="Level1"
                               VerticalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Text="Celer Beta" />
                    <Rectangle Width="1"
                               Height="24"
                               Margin="0,1,8,0"
                               Grid.Column="3"
                               Fill="{DynamicResource SurfaceStrokeColorDefaultBrush}"></Rectangle>
                    <ContentControl Content="{Binding MenuBarControl}"
                                    Focusable="False"
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    VerticalAlignment="Center"
                                    Grid.Column="4" />
                    <Border Grid.Column="5"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0" />
                    <UniformGrid Grid.Column="6"
                                 Columns="3"
                                 VerticalAlignment="Top">
                        <Button Padding="18,12"
                                Style="{DynamicResource TransparentButton}"
                                Click="MinimizeButton_Click"
                                Focusable="False"
                                x:Name="MinimizeButton"
                                local:ButtonHelper.CornerRadius="0">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Text="&#xE921;">
                            </TextBlock>
                        </Button>
                        <Button IsEnabled="{Binding IsEnabled, ElementName=MaximizeButton}"
                                Style="{DynamicResource TransparentButton}"
                                Click="RestoreOrMaximizeButton_Click"
                                Padding="18,12"
                                Focusable="False"
                                x:Name="MaximizeButton"
                                local:ButtonHelper.CornerRadius="0">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Text="&#xE922;"></TextBlock>
                        </Button>
                        <Button Style="{DynamicResource TransparentButton}"
                                Click="CloseButton_Click"
                                Padding="18,12"
                                Focusable="False"
                                x:Name="CloseButton"
                                local:ButtonHelper.BackgroundHover="#C42B1C"
                                local:ButtonHelper.CornerRadius="0">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Text="&#xE8BB;"></TextBlock>
                        </Button>
                    </UniformGrid>
                </Grid>
            </Grid>
            <!-- Main content -->
            <Border Grid.Row="1">
                <Grid>
                    <local:CompactTabControl  SelectedIndex="{Binding SelectedTabIndex}" 
                                              CompactMode="{Binding TabControlCompactMode, Mode=TwoWay}"
                                              Style="{StaticResource CelerStripTabLeft}"
                                              ItemsSource="{Binding TabsModule}"
                                              >
                        <local:CompactTabControl.Resources>
                            <Style TargetType="{x:Type iconPacks:PackIconLucide}">
                                <Setter Property="Width"
                                        Value="15" />
                                <Setter Property="Height"
                                        Value="15" />

                            </Style>
                        </local:CompactTabControl.Resources>
                        <local:CompactTabControl.ContentTemplate>
                            <DataTemplate DataType="{x:Type model:TabModule}">
                                <ContentPresenter x:Name="AnimatedContent"
                                                  Content="{Binding Content, NotifyOnTargetUpdated=True}">
                                    <ContentPresenter.RenderTransform>
                                        <TranslateTransform Y="20" />
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>

                                <DataTemplate.Triggers>
                                    <EventTrigger RoutedEvent="Binding.TargetUpdated"
                                                  SourceName="AnimatedContent">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="AnimatedContent"
                                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                 From="28"
                                                                 To="0"
                                                                 Duration="0:0:0.4">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CircleEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>

                                                <DoubleAnimation Storyboard.TargetName="AnimatedContent"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="0"
                                                                 To="1"
                                                                 Duration="0:0:0.2" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </local:CompactTabControl.ContentTemplate>
                    </local:CompactTabControl>
                </Grid>
            </Border>
            <!-- Quick Center -->
            <tb:TaskbarIcon IconSource="/celer_icon.ico"
                            ToolTipText="Celer"
                            d:DataContext="{d:DesignInstance Type=viewmodels:QCMenuViewModel}">
                <tb:TaskbarIcon.TrayPopup>
                    <mainwindow:QuickCenter></mainwindow:QuickCenter>
                </tb:TaskbarIcon.TrayPopup>
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu x:Name="QCMenu">
                        <MenuItem Header="Open"
                                  Command="{Binding QCOpenAppCommand}" />
                        <MenuItem Header="Exit"
                                  Command="{Binding QCExitAppCommand}" />
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
        </Grid>
    </Border>
</Window>

