<Window
    x:Class="Celer.Views.Windows.Onboarding"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:custom="clr-namespace:Celer.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:Celer.Views.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resx="clr-namespace:Celer.Resources.i18n"
    Title="{x:Static resx:Strings.Onboarding_WindowTitle}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Width="800"
    Icon="/Resources/Assets/app.ico"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Border Grid.Column="1" Padding="16,8,16,16">
            <StackPanel>
                <StackPanel.Resources>
                    <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
                        <Setter Property="Margin" Value="0,0,0,8" />
                    </Style>
                </StackPanel.Resources>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource Heading1}" Text="{x:Static resx:Strings.Onboarding_WelcomeTitle}" />
                        <TextBlock
                            Margin="0,4,0,8"
                            MaxWidth="400"
                            HorizontalAlignment="Left"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource Subheading}"
                            Text="{x:Static resx:Strings.Onboarding_WelcomeIntroduction}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <Image
                        Grid.Column="1"
                        Width="64"
                        Margin="16,0,0,0"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Source="/Resources/Assets/app.ico" />
                </Grid>
                <TextBlock
                    Margin="0,0,0,10"
                    Style="{StaticResource Heading2}"
                    Text="{x:Static resx:Strings.Onboarding_LegalTitle}" />
                <Border
                    Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <ScrollViewer MaxHeight="195" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10,10,16,10">
                            <StackPanel.Resources>
                                <Style
                                    x:Key="Heading"
                                    BasedOn="{StaticResource {x:Type TextBlock}}"
                                    TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="DemiBold" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <Setter Property="Margin" Value="0,4" />
                                </Style>
                            </StackPanel.Resources>
                            <TextBlock FontStyle="Italic" Foreground="{DynamicResource TextFillColorSecondaryBrush}">Last revision from June 19, 2025</TextBlock>
                            <TextBlock Style="{StaticResource Heading}">1. Acceptance of Terms</TextBlock>
                            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap">By installing, using, or accessing Celer, the user declares that they have read, understood, and accepted these Terms of Use. If you do not agree with these terms, you must uninstall and stop using Celer immediately.</TextBlock>
                            <TextBlock Style="{StaticResource Heading}">2. License of Use</TextBlock>
                            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap">A free, non-exclusive, and revocable license is granted to the user to use Celer solely for personal and non-commercial purposes. Modification, redistribution, or incorporation of the software into other products must comply with the open-source license under which Celer is made available.</TextBlock>
                            <TextBlock Style="{StaticResource Heading}">3. Disclaimer</TextBlock>
                            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap">
                                Celer is provided "as is", without any kind of warranty, either express or implied.<LineBreak />
                                SurfScape and its contributors assume no responsibility for direct, indirect, incidental, consequential, or other damages that may result from the use of Celer.<LineBreak />
                                The use of the application is entirely at the user's own risk.</TextBlock>
                            <TextBlock Style="{StaticResource Heading}">4. Updates and Connectivity</TextBlock>
                            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap">Celer may, with the user's consent, download automatic updates, as well as updated signatures and configurations. This is only used for the cleaning functionality, with the rest of Celer still being fully functional.</TextBlock>
                            <TextBlock Style="{StaticResource Heading}">5. Privacy and Data</TextBlock>
                            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap">Celer does not collect or transmit personal data with or without the user's consent.</TextBlock>
                            <TextBlock Style="{StaticResource Heading}">6. Changes to the Terms</TextBlock>
                            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap">SurfScape reserves the right to modify these Terms of Use at any time. Whenever this occurs, a new version will be made available within the application. Continued use after changes constitutes acceptance of the updated terms.</TextBlock>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
                <StackPanel x:Name="OnboardingOptions">
                    <CheckBox VerticalAlignment="Stretch" IsChecked="{Binding AcceptTerms}">
                        <TextBlock Margin="0,0,0,0" VerticalAlignment="Bottom">
                            <Run Text="{x:Static resx:Strings.Onboarding_LegalCheckboxLabel}" />
                            <Hyperlink
                                custom:HyperlinkExtensions.IsExternal="True"
                                Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                NavigateUri="https://surfscape.eu/projects/celer/legal/privacy/">
                                Privacy Policy
                            </Hyperlink></TextBlock>
                    </CheckBox>
                    <TextBlock  FontSize="16" FontWeight="SemiBold" Margin="0,10,0,6">Features</TextBlock>
                    <CheckBox IsChecked="{Binding AutoUpdates}">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Margin="0" Text="{x:Static resx:Strings.Onboarding_AutoDownloadsCheckboxLabel}" />
                            <StackPanel
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                VerticalAlignment="Bottom"
                                Background="Transparent"
                                ToolTip="Update Celer's signatures when starting up without manually updating them from the Tools menu.">
                                <iconPacks:PackIconLucide
                                    Width="14"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Kind="BadgeQuestionMark" />
                            </StackPanel>
                        </Grid>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding AutoStartup}">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Margin="0" Text="Start with WIndows" />
                            <StackPanel
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                VerticalAlignment="Bottom"
                                Background="Transparent"
                                ToolTip="Allow Celer to run on startup with Windows, this will also allow you to use Celer's Quick Launch feature">
                                <iconPacks:PackIconLucide
                                    Width="14"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Kind="BadgeQuestionMark" />
                            </StackPanel>
                        </Grid>
                    </CheckBox>
                    <Button
                        MinWidth="140"
                        HorizontalAlignment="Right"
                        Command="{Binding StartCommand}"
                        IsEnabled="{Binding AcceptTerms}"
                        Style="{DynamicResource AccentButtonStyle}">
                        Start
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
