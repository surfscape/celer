<UserControl
    x:Class="Celer.Views.Pages.Settings.SettingsModuleCleaning"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Celer.Views.Pages.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Celer.Controls"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel>
        <uc:CelerOption
            Title="Export cleaning log"
            Description="Celer will export a .txt log of the cleaning process"
            Icon="ScrollText">
            <CheckBox
                VerticalAlignment="Stretch"
                IsChecked="{Binding EnableExportCleaningLog}"
                Style="{StaticResource SwitchCheckBoxStyle}" />
        </uc:CelerOption>
    </StackPanel>
</UserControl>
