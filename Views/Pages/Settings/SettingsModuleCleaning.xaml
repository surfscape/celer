<UserControl
    x:Class="Celer.Views.Pages.Settings.SettingsModuleCleaning"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Celer.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:Celer.Views.Pages.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Celer.Controls"
    d:DataContext="{d:DesignInstance Type=local:SettingsModuleCleaningViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter" />
        <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
    </UserControl.Resources>
    <StackPanel>
        <uc:CelerOption
            Title="Export cleaning log"
            Description="Celer will export a .txt log of the cleaning process"
            Icon="ScrollText">
            <CheckBox
                VerticalAlignment="Stretch"
                IsChecked="{Binding EnableExportCleaningLog}"
                Style="{StaticResource SwitchCheckBoxStyle}" />
        </uc:CelerOption>
        <Border
            Margin="0,4"
            Padding="16,16"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="6">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconLucide
                        Width="20"
                        Height="20"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Kind="Folder" />
                    <StackPanel Grid.Column="1">
                        <TextBlock
                            Margin="0,0,0,2"
                            Style="{DynamicResource BodyStrongTextBlockStyle}"
                            Text="Custom folders and files" />
                        <TextBlock
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Style="{DynamicResource BodyTextBlockStyle}"
                            Text="Add your own folders and files that you want to delete/clean" />
                    </StackPanel>
                </StackPanel>
                <StackPanel>
                    <ListBox
                        x:Name="pathsListBox"
                        Margin="0,12"
                        ItemsSource="{Binding Paths}" />
                    <TextBlock
                        Margin="0,24"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="No folders or files defined"
                        Visibility="{Binding Paths.Count, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=true}" />
                    <StackPanel Orientation="Horizontal">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding PickAndAddPathCommand}"
                            Content="Add new folder/file" />
                        <Button
                            Command="{Binding RemovePathCommand}"
                            CommandParameter="{Binding SelectedItem, ElementName=pathsListBox}"
                            Content="Remove"
                            IsEnabled="{Binding SelectedItem, ElementName=pathsListBox, Converter={StaticResource NullToBoolConverter}}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
