<UserControl
    x:Class="Celer.Views.Pages.Settings.SettingsInterface"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Celer.Views.Pages.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Celer.Controls"
    d:DataContext="{d:DesignInstance Type=local:SettingsInterfaceViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <StackPanel>
            <uc:CelerOption
                Title="Application Theme"
                Description="Change the current color scheme of the app, or use the system's theme"
                Icon="Palette">
                <ComboBox
                            Grid.Column="1"
                            MinWidth="170"
                            ItemsSource="{Binding Themes}"
                            SelectedItem="{Binding CurrentTheme, Mode=TwoWay}" />
            </uc:CelerOption>
            <uc:CelerOption
                Title="Stretch view content to window"
                Description="Allows the view content to stretch to the Window width instead of being limited to 980px"
                Icon="Expand">
                <CheckBox
                    IsChecked="{Binding EnableFillContent}"
                    Style="{StaticResource SwitchCheckBoxStyle}"
                    ToolTip="When enabled, content will expand to fill the window size." />
            </uc:CelerOption>
            <uc:CelerOption
                Title="Round values"
                Description="Allow rounding of double and float values. Some values may not respect this preference"
                Icon="DecimalsArrowLeft">
                <CheckBox
                    IsChecked="{Binding EnableRounding}"
                    Style="{StaticResource SwitchCheckBoxStyle}"/>
            </uc:CelerOption>
            <uc:CelerOption
                Title="Save sidebar compact state"
                Description="By default Celer will perserve the last sidebar state when relaunching. This will disable that feature"
                Icon="PanelLeftDashed">
                <CheckBox
                    IsChecked="{Binding SaveSidebarCompactMode}"
                    Style="{StaticResource SwitchCheckBoxStyle}"/>
            </uc:CelerOption>
            <TextBlock Margin="0,12,0,12" Style="{DynamicResource Heading1}">Startup</TextBlock>
            <Border
                Padding="12"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <CheckBox IsChecked="{Binding StartWithWindows}" ToolTip="Start Celer minimized when Windows starts">Start with Windows</CheckBox>
                    <CheckBox IsChecked="{Binding CloseShouldMinimize}" ToolTip="Closing will make Celer go into the icon tray">Close should minimize to the icon tray</CheckBox>
                </StackPanel>
            </Border>
            <TextBlock
                Margin="0,12,0,4"
                Style="{DynamicResource Heading2}"
                Visibility="Collapsed">
                Dashboard
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
