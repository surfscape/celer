<UserControl
    x:Class="Celer.Views.Pages.Settings.SettingsGeneral"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:custom="clr-namespace:Celer.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Celer.Views.Pages.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Celer.Controls"
    d:DataContext="{d:DesignInstance Type=local:SettingsGeneralViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">
    <Grid>
        <StackPanel>
            <TextBlock Margin="0,0,0,8" Style="{StaticResource BodyStrongTextBlockStyle}">Startup</TextBlock>
            <uc:CelerOption
                Title="Start with Windows"
                Description="Start Celer with Windows. This enables access to Celer Quick Center available in the system tray"
                Icon="Power">
                <CheckBox
                    VerticalAlignment="Stretch"
                    IsChecked="{Binding StartWithWindows}"
                    Style="{StaticResource SwitchCheckBoxStyle}" />
            </uc:CelerOption>
            <uc:CelerOption
                Title="Close should minimize"
                Description="Celer will minimize to the system tray instead of closing all together"
                Icon="Minimize">
                <CheckBox
                    VerticalAlignment="Stretch"
                    IsChecked="{Binding CloseShouldMinimize}"
                    Style="{StaticResource SwitchCheckBoxStyle}" />
            </uc:CelerOption>
            <TextBlock Margin="0,8" Style="{StaticResource BodyStrongTextBlockStyle}">Network</TextBlock>
            <uc:CelerOption
                Title="Enable SurfScape Gateway Services"
                Description="Enable SurfScape Gatway Services, these provide updates to various components of Celer without requiring to update the entire app"
                Image="/Resources/Assets/gateway_icon.png">
                <CheckBox
                    VerticalAlignment="Stretch"
                    IsChecked="{Binding EnableSurfScapeGateway}"
                    Style="{StaticResource SwitchCheckBoxStyle}" />
            </uc:CelerOption>
            <uc:CelerOption
                Title="Update SurfScape Gateway on launch"
                Description="Update Celer's signatures through the internet automatically on launch"
                Image="/Resources/Assets/gateway_icon.png">
                <CheckBox
                    VerticalAlignment="Stretch"
                    IsChecked="{Binding UpdateGatewayLaunch}"
                    IsEnabled="{Binding EnableSurfScapeGateway}"
                    Style="{StaticResource SwitchCheckBoxStyle}" />
            </uc:CelerOption>
            <TextBlock Margin="0,4,0,0" FontSize="14">
                <Hyperlink custom:HyperlinkExtensions.IsExternal="True" NavigateUri="https://gateway.surfscape.eu/">Learn more about SurfScape Gateway</Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
