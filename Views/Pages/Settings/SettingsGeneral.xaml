<UserControl
    x:Class="Celer.Views.Pages.Settings.SettingsGeneral"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Celer.Views.Pages.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Celer.Controls"
    d:DataContext="{d:DesignInstance Type=local:SettingsGeneralViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">
    <Grid>
        <StackPanel>
            <TextBlock Margin="0,0,0,16" Style="{DynamicResource Heading2}">Appearance and Presentation</TextBlock>
            <Border
                Padding="12"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorOnAccentSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="17"
                                FontWeight="DemiBold"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="Application Theme" />
                        </StackPanel>
                        <ComboBox
                            Grid.Column="1"
                            MinWidth="170"
                            ItemsSource="{Binding Themes}"
                            SelectedItem="{Binding CurrentTheme, Mode=TwoWay}" />
                    </Grid>
                    <CheckBox IsChecked="{Binding EnableFillContent}" ToolTip="When enabled, content will expand to fill the window size.">Fill content to window size</CheckBox>
                    <CheckBox IsChecked="{Binding EnableRounding}" ToolTip="Round most values to one decimal case. Some values may not respect this preference.">Round values</CheckBox>
                    <CheckBox IsChecked="{Binding SaveSidebarCompactMode}" ToolTip="By default Celer will perserve the last sidebar mode state when relaunching. This will disable that feature">Save sidebar state</CheckBox>
                </StackPanel>
            </Border>
            <TextBlock Margin="0,12,0,12" Style="{DynamicResource Heading1}">Startup</TextBlock>
            <Border
                Padding="12"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <CheckBox IsChecked="{Binding StartWithWindows}" ToolTip="Start Celer minimized when Windows starts">Start with Windows</CheckBox>
                    <CheckBox IsChecked="{Binding CloseShouldMinimize}" ToolTip="Closing will make Celer go into the icon tray">Close should minimize to the icon tray</CheckBox>
                </StackPanel>
            </Border>
            <TextBlock
                Margin="0,12,0,4"
                Style="{DynamicResource Heading2}"
                Visibility="Collapsed">
                Dashboard
            </TextBlock>
            <Border
                Padding="12"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,8"
                        VerticalAlignment="Center"
                        FontWeight="DemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="Alerts" />
                    <StackPanel VerticalAlignment="Top" Orientation="Vertical">
                        <CheckBox
                            Content="Enable Alerts"
                            IsChecked="{Binding EnableAlerts, Mode=TwoWay}"
                            IsThreeState="True" />
                        <StackPanel Margin="20,4">
                            <CheckBox
                                Content="Enable CPU monitoring (triggers at 80%)"
                                IsChecked="{Binding EnableAlertCPUTracking, Mode=TwoWay}"
                                IsEnabled="{Binding AreInnerAlertsEnabled, Mode=OneWay}" />
                            <CheckBox
                                Content="Enable memory monitoring (triggers at 80%)"
                                IsChecked="{Binding EnableAlertMemoryTracking, Mode=TwoWay}"
                                IsEnabled="{Binding AreInnerAlertsEnabled, Mode=OneWay}" />
                            <CheckBox
                                Content="Enable process monitoring memory usage (triggers at 500MB)"
                                IsChecked="{Binding EnableAlertTrackProcess, Mode=TwoWay}"
                                IsEnabled="{Binding AreInnerAlertsEnabled, Mode=OneWay}" />
                            <Label Content="Process to monitor" IsEnabled="{Binding IsProcessTrackingTextBoxEnabled, Mode=OneWay}" />
                            <TextBox IsEnabled="{Binding IsProcessTrackingTextBoxEnabled, Mode=OneWay}" Text="{Binding TrackProcess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
            <uc:SettingCategoryButton
                Title="Design and Presentation"
                Margin="0,16,0,0"
                Description="Change how values are shown and the general app theme"
                Icon="Rocket" />
            <uc:SettingCategoryButton
                Title="Design and Presentation"
                Margin="0,16,0,0"
                Description="Change how values are shown and the general app theme"
                Icon="Rocket" />

        </StackPanel>
    </Grid>
</UserControl>
