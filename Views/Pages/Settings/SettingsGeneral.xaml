<UserControl x:Class="Celer.Views.Pages.Settings.SettingsGeneral"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Celer.Views.Pages.Settings"
             xmlns:uc="clr-namespace:Celer.Controls"
             mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <Grid>
        <StackPanel>
            <TextBlock Style="{DynamicResource Heading1}"
                       Margin="0,0,0,12">Appearance and Presentation</TextBlock>
            <Border CornerRadius="4"
                    Padding="12"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock VerticalAlignment="Center"
                                       Text="Theme"
                                       FontSize="17"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       FontWeight="DemiBold" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
         Changes the global application theme
                            </TextBlock>
                        </StackPanel>
                        <ComboBox Padding="12,0,4,1"
                                  Grid.Column="1"
                                  MinWidth="150"
                                  ItemsSource="{Binding Themes}"
                                  SelectedItem="{Binding CurrentTheme, Mode=TwoWay}" />
                    </Grid>
                    <CheckBox IsChecked="{Binding EnableRounding}"
                              ToolTip="Round most values to one decimal case. Do note that some values may not respect this preference.">Round values</CheckBox>
                    <CheckBox IsChecked="{Binding SaveSidebarCompactMode}"
                              ToolTip="Saves the current sidebar compact state.">Save sidebar state</CheckBox>
                </StackPanel>
            </Border>
            <TextBlock Style="{DynamicResource Heading1}"
                       Margin="0,12,0,12">Startup</TextBlock>
            <Border CornerRadius="4"
                    Padding="12"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <StackPanel>
                    <CheckBox IsChecked="{Binding StartWithWindows}"
                              ToolTip="Start Celer minimized when Windows starts">Start with Windows</CheckBox>
                    <CheckBox IsChecked="{Binding CloseShouldMinimize}"
                              ToolTip="Closing will make Celer go into the icon tray">Close should minimize to the icon tray</CheckBox>
                </StackPanel>
            </Border>
            <TextBlock Visibility="Collapsed"
                       Margin="0,12,0,4"
                       Style="{DynamicResource Heading2}">Dashboard
            </TextBlock>
            <Border CornerRadius="8"
                    Padding="12"
                    Visibility="Collapsed"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <StackPanel>
                    <TextBlock VerticalAlignment="Center"
                               Text="Alerts"
                               Margin="0,0,0,8"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               FontWeight="DemiBold" />
                    <StackPanel VerticalAlignment="Top"
                                Orientation="Vertical">
                        <CheckBox Content="Enable Alerts"
                                  IsChecked="{Binding EnableAlerts, Mode=TwoWay}"
                                  IsThreeState="True" />
                        <StackPanel Margin="20,4">
                            <CheckBox Content="Enable CPU monitoring (triggers at 80%)"
                                      IsChecked="{Binding EnableAlertCPUTracking, Mode=TwoWay}"
                                      IsEnabled="{Binding AreInnerAlertsEnabled, Mode=OneWay}" />
                            <CheckBox Content="Enable memory monitoring (triggers at 80%)"
                                      IsChecked="{Binding EnableAlertMemoryTracking, Mode=TwoWay}"
                                      IsEnabled="{Binding AreInnerAlertsEnabled, Mode=OneWay}" />
                            <CheckBox Content="Enable process monitoring memory usage (triggers at 500MB)"
                                      IsChecked="{Binding EnableAlertTrackProcess, Mode=TwoWay}"
                                      IsEnabled="{Binding AreInnerAlertsEnabled, Mode=OneWay}" />
                            <Label Content="Process to monitor"
                                   IsEnabled="{Binding IsProcessTrackingTextBoxEnabled, Mode=OneWay}" />
                            <TextBox IsEnabled="{Binding IsProcessTrackingTextBoxEnabled, Mode=OneWay}"
                                     Text="{Binding TrackProcess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
            <uc:SettingCategoryButton Margin="0,16,0,0"
                                      Title="Design and Presentation"
                                      Icon="Rocket"
                                      Description="Change how values are shown and the general app theme"></uc:SettingCategoryButton>
            <uc:SettingCategoryButton Margin="0,16,0,0"
                                      Title="Design and Presentation"
                                      Icon="Rocket"
                                      Description="Change how values are shown and the general app theme"></uc:SettingCategoryButton>
            <uc:ComplexExpander Title="Theme" Description="Change Theme" Icon="Accessibility">
                <Button>Test</Button>
            </uc:ComplexExpander>
        </StackPanel>
    </Grid>
</UserControl>
