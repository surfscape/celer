<UserControl x:Class="Celer.Views.Pages.Settings.SettingsShell"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Celer.Views.Pages.Settings"
      xmlns:uc="clr-namespace:Celer.Controls"
      d:DataContext="{d:DesignInstance Type=local:SettingsShellViewModel}"
      mc:Ignorable="d" 
             VerticalAlignment="Top"
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid ScrollViewer.VerticalScrollBarVisibility="Visible" Height="auto" VerticalAlignment="Top">
        <StackPanel VerticalAlignment="Top"
                    Height="auto">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,0,0,16">Celer Settings</TextBlock>
            <uc:SettingCategoryButton Title="General preferences"
                                      Icon="Settings"
                                      Description="Telemetry, and manage Celer settings"
                                      Command="{Binding NavigateToGeneralCommand}"></uc:SettingCategoryButton>
            <uc:SettingCategoryButton Margin="0,4,0,0"
                                      Title="User Interface &amp; presentation"
                                      Icon="Palette"
                                      Description="Change how values are shown and the general app theme"></uc:SettingCategoryButton>
            <uc:SettingCategoryButton Margin="0,24,0,0"
                                      Title="Startup &amp; system tray"
                                      Icon="Power"
                                      Description="Change startup behaviour and manage Celer Quick Center"></uc:SettingCategoryButton>
            <uc:SettingCategoryButton Margin="0,4,0,0"
                                      Title="Cleaning options"
                                      Icon="Trash"
                                      Description="Add folders/files for cleaning and change the signatures source"></uc:SettingCategoryButton>
            <uc:SettingCategoryButton Margin="0,24,0,0"
                                      Title="Advanced options"
                                      Icon="FlaskConical"
                                      Command="{Binding NavigateToAdvancedCommand}"
                                      Description="Read &amp; export debug information and enable experimental options"></uc:SettingCategoryButton>
        </StackPanel>
    </Grid>
</UserControl>
