<UserControl
    x:Class="Celer.Views.Pages.Settings.SettingsAdvanced"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:co="clr-namespace:Celer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:Celer.Views.Pages.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Celer.Controls"
    d:DataContext="{d:DesignInstance Type=local:SettingsAdvancedViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid RowDefinitions="auto auto auto">
        <StackPanel>
            <uc:CelerOption
                Title="Polling Rate"
                Description="How much time Celer takes to refresh information"
                Icon="Timer">
                <ComboBox
                    Grid.Column="2"
                    MinWidth="165"
                    DisplayMemberPath="Key"
                    ItemsSource="{Binding PollingOptions}"
                    SelectedItem="{Binding PoolingRate}" />
            </uc:CelerOption>
            <uc:CelerOption
                Title="Rendering Mode"
                Description="Choose what graphic rendering mode to use"
                Icon="Gpu">
                <ComboBox
                    Grid.Column="2"
                    MinWidth="165"
                    VerticalAlignment="Center"
                    ItemsSource="{Binding RenderingModes}"
                    SelectedIndex="{Binding GraphicRenderingMode, Mode=TwoWay}" />
            </uc:CelerOption>
            <uc:CelerOption
                Title="Reset Celer configurations"
                Description="Reset application settings to the default, Celer will then launch as if it was just installed"
                Icon="Settings2">
                <Button BorderBrush="Transparent" Foreground="{DynamicResource SystemFillColorCriticalBrush}" Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}">
                    Reset
                </Button>
            </uc:CelerOption>
            <uc:ComplexExpander
                Title="Debug Information"
                Grid.Row="2"
                Margin="0,12,0,0"
                Icon="Code">
                <StackPanel>
                    <TextBlock
                        Margin="0,4,30,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{Binding ProcessMemory, StringFormat=Process memory: {0:#}}" />
                    <TextBlock
                        Margin="0,4,30,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{Binding BuildType, StringFormat=Build type: {0}}" />
                </StackPanel>
            </uc:ComplexExpander>
        </StackPanel>
    </Grid>
</UserControl>
