<UserControl
    x:Class="Celer.Views.UserControls.MainApp.Cleaning"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Celer.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Celer.Views.UserControls.MainApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:Celer.Utilities"
    xmlns:viewmodels="clr-namespace:Celer.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:CleanEngine}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:MemorySizeConverter x:Key="MemorySizeConverter" />
        <converters:EmptyToVisibilityConverter x:Key="EmptyToVisibilityConverter" />
    </UserControl.Resources>
    <Grid VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Padding="0,0,0,16">
            <StackPanel>
                <TextBlock Style="{StaticResource Heading1}">Cleaning</TextBlock>
                <TextBlock Style="{StaticResource Subheading}">Delete temporary files, third party app cache, and other unnecessary files.</TextBlock>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1" VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>
            <ScrollViewer
                utils:ScrollUtilities.SmoothScroll="True"
                Focusable="False"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <ItemsControl Padding="0,0,0,16" ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="0,0,12,2" IsExpanded="True">
                                <Expander.Header>
                                    <TextBlock Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="{Binding Name}" />
                                </Expander.Header>
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="4">
                                                <CheckBox
                                                    VerticalAlignment="Center"
                                                    Content="{Binding Name}"
                                                    IsChecked="{Binding IsChecked}"
                                                    ToolTip="{Binding Description}" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <Border
                Grid.Column="1"
                Margin="0,0,0,16"
                Padding="12"
                VerticalAlignment="Stretch"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Margin="0,0,0,8"
                        Style="{DynamicResource Heading2}"
                        Text="Log" />

                    <ListBox
                        Name="LogListBox"
                        Grid.Row="1"
                        VerticalAlignment="Stretch"
                        ItemsSource="{Binding LogEntries}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.ScrollChanged="ScrollViewer_OnScrollChanged"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="{x:Type ListBoxItem}">
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="IsHitTestVisible" Value="False" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Foreground="{Binding LogColor}"
                                    Text="{Binding LogEntry}"
                                    TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Grid.Row="2" RowDefinitions="auto auto">
                        <TextBlock
                            Margin="0,0,0,8"
                            Foreground="{StaticResource TextFillColorSecondaryBrush}"
                            Style="{DynamicResource CaptionTextBlockStyle}"
                            Text="{Binding TotalFreedText, StringFormat=Space freed: {0}}"
                            Visibility="{Binding TotalFreedText, Converter={StaticResource EmptyToVisibilityConverter}, ConverterParameter=Hidden}" />
                        <Button
                            Grid.Row="1"
                            HorizontalAlignment="Right"
                            Command="{Binding CleanCommand}"
                            Content="Start Cleaning"
                            IsEnabled="{Binding CanClean}"
                            Style="{DynamicResource AccentButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
