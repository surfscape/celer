<UserControl
    x:Class="Celer.Views.UserControls.MainApp.OptimizationViews.Battery"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Optimization="clr-namespace:Celer.ViewModels.OptimizationVM"
    xmlns:components="clr-namespace:Celer.Views.Components"
    xmlns:controls="clr-namespace:Celer.Controls"
    xmlns:converters="clr-namespace:Celer.Converters"
    xmlns:convertersBat="clr-namespace:Celer.Converters.Battery"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:Celer.Views.UserControls.MainApp.OptimizationViews"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="white"
    d:DataContext="{d:DesignInstance Type=Optimization:BatteryViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    d:Foreground="black"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <convertersBat:ChargingConverter x:Key="ChargingConverter" />
        <convertersBat:BatteryIconConverter x:Key="BatteryIconConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <components:ModuleLoadingStatus Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=True}">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Margin="0,0,0,16" Visibility="{Binding BatteryStaticData.Available, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
                            <Setter Property="Margin" Value="0,0,0,8" />
                        </Style>
                    </StackPanel.Resources>
                    <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                        <iconPacks:PackIconLucide
                            Width="42"
                            Height="42"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Kind="{Binding BatteryStats.Percentage, Converter={StaticResource BatteryIconConverter}}" />
                        <TextBlock
                            Margin="0"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Style="{StaticResource TitleLargeTextBlockStyle}"
                            Text="{Binding BatteryStats.Percentage, StringFormat={}{0}%}" />
                    </StackPanel>

                    <Grid Margin="0,8">
                        <Grid.Resources>
                            <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
                                <Setter Property="Margin" Value="0,0,16,0" />
                            </Style>
                        </Grid.Resources>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="{Binding BatteryStats.IsCharging, StringFormat={}{0}, Converter={StaticResource ChargingConverter}}" />
                            <TextBlock
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="{Binding BatteryStats.EstimatedRunTime, StringFormat='Remaining Time: {0:g}'}"
                                Visibility="{Binding BatteryStats.IsCharging, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=true}" />
                        </StackPanel>
                        <Border Grid.Column="1" CornerRadius="8">
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid>
                                    <ProgressBar
                                        Height="16"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource ControlStrongFillColorDisabledBrush}"
                                        Maximum="100"
                                        Minimum="0"
                                        Value="0" />
                                    <ProgressBar
                                        Height="16"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Panel.ZIndex="2"
                                        Background="Transparent"
                                        Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                        Maximum="100"
                                        Minimum="0"
                                        Value="{Binding BatteryStats.Health}" />
                                    <ProgressBar
                                        Height="16"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Panel.ZIndex="3"
                                        Background="Transparent"
                                        Foreground="{DynamicResource SmokeFillColorDefaultBrush}"
                                        Maximum="100"
                                        Minimum="0"
                                        Value="{Binding BatteryStats.RemainingChargeCapacityPercentage}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <StackPanel Margin="0,0,24,0" Orientation="Horizontal">
                            <iconPacks:PackIconLucide
                                Width="20"
                                Height="20"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Kind="BatteryPlus" />
                            <TextBlock
                                Margin="0,0,0,2"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="{Binding BatteryStats.Health, StringFormat='{}{0}%'}"
                                ToolTip="Battery Health" />
                        </StackPanel>

                        <StackPanel Margin="0,0,12,0" Orientation="Horizontal">
                            <Border
                                Width="15"
                                Height="15"
                                Margin="0,0,6,0"
                                Background="{DynamicResource SystemFillColorSuccessBrush}"
                                CornerRadius="10">
                                <Border
                                    Width="15"
                                    Height="15"
                                    Background="{DynamicResource SmokeFillColorDefaultBrush}"
                                    CornerRadius="10" />
                            </Border>
                            <TextBlock
                                Margin="0"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="{Binding BatteryStats.RemainingChargeCapacity, StringFormat='{}{0} mWh'}"
                                ToolTip="Current charged capacity" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0" Orientation="Horizontal">
                            <Border
                                Width="15"
                                Height="15"
                                Margin="0,0,6,0"
                                Background="{DynamicResource SystemFillColorSuccessBrush}"
                                CornerRadius="10" />
                            <TextBlock
                                Margin="0"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="{Binding BatteryStats.RemainingFullCapacity, StringFormat='{}{0} mWh'}"
                                ToolTip="Full charge capacity" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border
                                Width="15"
                                Height="15"
                                Margin="0,0,6,0"
                                Background="{DynamicResource ControlStrongFillColorDisabledBrush}"
                                CornerRadius="10" />
                            <TextBlock
                                Margin="0"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="{Binding BatteryStats.FullDesignCapacity, StringFormat='{}{0} mWh'}"
                                ToolTip="Original capacity" />
                        </StackPanel>

                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <ScrollViewer
                Grid.Row="1"
                Margin="0,0,-16,0"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,16,0">
                    <controls:ComplexExpander
                        Title="Power Modes"
                        Margin="0,0,0,4"
                        Description="Optimize the system based on it's current workflow to balance performance and energy consumption"
                        Icon="Gauge">
                        <StackPanel Margin="6,0,6,0">
                            <Grid Visibility="{Binding IsLegacyPowerPlansEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="Legacy Power Plans" />
                                    <TextBlock
                                        Margin="0,4,30,0"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="Change the active power plan, provided by powercfg" />
                                </StackPanel>
                                <ComboBox
                                    Grid.Column="1"
                                    MinWidth="190"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{Binding PowerPlans}"
                                    SelectedValue="{Binding SelectedPowerPlan.Name, Mode=TwoWay}"
                                    SelectedValuePath="Name" />
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button
                                        Margin="8,0,8,0"
                                        Command="{Binding ApplyPowerPlanCommand}"
                                        Content="Apply"
                                        Style="{DynamicResource AccentButtonStyle}" />
                                    <Button Command="{Binding InstallPlansCommand}" Content="Install More Plans" />
                                </StackPanel>
                            </Grid>
                            <Border
                                Margin="0,12"
                                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="0,1,0,0"
                                Visibility="{Binding IsLegacyPowerPlansEnabled, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=true}" />
                            <Grid Visibility="{Binding IsLegacyPowerPlansEnabled, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=true}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="New Power Modes" />
                                    <TextBlock
                                        Margin="0,4,30,0"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="Switch to the different power modes" />
                                </StackPanel>
                                <ComboBox
                                    Grid.Column="1"
                                    MinWidth="190"
                                    DisplayMemberPath="Name" />
                                <Button
                                    Grid.Column="2"
                                    Margin="8,0,8,0"
                                    Command="{Binding ApplyPowerPlanCommand}"
                                    Content="Apply"
                                    Style="{DynamicResource AccentButtonStyle}" />
                            </Grid>
                        </StackPanel>
                    </controls:ComplexExpander>
                    <controls:ComplexExpander
                        Title="Advanced Settings"
                        Description="Change advanced energy parameters like fast startup, hibernation, and more"
                        Icon="Wrench">
                        <StackPanel Margin="6,0,6,0">
                            <StackPanel Margin="0,0,0,12">
                                <CheckBox VerticalContentAlignment="Center" IsChecked="{Binding IsFastBootEnabled, Mode=TwoWay}">
                                    <CheckBox.Content>
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Foreground="{DynamicResource TextFillColorPrimaryBrush}">Enable Fast Startup</TextBlock>
                                            <TextBlock
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource BodyTextBlockStyle}"
                                                TextWrapping="Wrap">
                                                Skips some hardware checks to speedup the startup process. If you have hardware conflits or you're on a dual boot system, it's recommended to disable this feature.
                                            </TextBlock>
                                        </StackPanel>
                                    </CheckBox.Content>
                                </CheckBox>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <CheckBox IsChecked="{Binding IsHibernationEnabled, Mode=TwoWay}">
                                    <CheckBox.Content>
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Foreground="{DynamicResource TextFillColorPrimaryBrush}">Enable Hibernation</TextBlock>
                                            <TextBlock
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource BodyTextBlockStyle}"
                                                TextWrapping="Wrap">
                                                Saves the current state of the system into disk when the PC shuts down and resumes when logged back in. It can cause issues when dual booting with Linux.
                                            </TextBlock>
                                        </StackPanel>
                                    </CheckBox.Content>
                                </CheckBox>
                            </StackPanel>
                        </StackPanel>
                    </controls:ComplexExpander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
