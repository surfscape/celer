<UserControl
    x:Class="Celer.Views.UserControls.MainApp.MaintenanceViews.Network"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Celer.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Celer.Views.UserControls.MainApp.MaintenanceViews"
    xmlns:vm="clr-namespace:Celer.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             d:DataContext="{d:DesignInstance Type=vm:MaintenanceVM.NetworkViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    d:Background="white"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource Heading2}">Network and Internet</TextBlock>
            <UniformGrid Columns="3" Margin="0,12">
                <StackPanel>
                    <TextBlock FontSize="17"
                               FontWeight="DemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Network Adapters" />
                    <TextBlock Text="{Binding AdaptersFound}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock
                        
                               FontSize="17"
                               FontWeight="DemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Text="Connection" />
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock FontSize="17"
                               FontWeight="DemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Text="Internet Access" />
                    <TextBlock Text="{Binding InternetConnectionStatus}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </UniformGrid>
            <Button Width="125"
                    Command="{Binding TestNetworkCommand}"
                    Content="Check" />
        </StackPanel>
        <Border Grid.Row="1"
                Padding="12"
                BorderThickness="1"
                CornerRadius="6"
                Margin="0,12,0,0"
                HorizontalAlignment="Left"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel>
                <TextBlock Style="{StaticResource Heading2}">DNS Manager</TextBlock>
                <StackPanel VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Margin="0,6,0,12">
                    <ComboBox Width="300"
                              Height="30"
                              ItemsSource="{Binding DnsServers}"
                              SelectedItem="{Binding SelectedDnsServer}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontWeight="Bold"
                                               Text="{Binding Name}" />
                                    <TextBlock Text=" - " />
                                    <TextBlock Text="{Binding IP}" />
                                    <TextBlock Text=" (" />
                                    <TextBlock Text="{Binding PingStatus}" />
                                    <TextBlock Text=" ms)" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Margin="10,0,0,0"
                            Padding="8"
                            ToolTip="Refresh Ping"
                            Command="{Binding UpdatePingCommand}">
                        <iconPacks:PackIconLucide Width="14"
                                                  Height="14"
                                                  Kind="RefreshCw" />
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding SetDnsCommand}"
                            Content="Apply DNS as system-wide"
                            IsEnabled="{Binding SelectedDnsServer, Converter={StaticResource NullToBoolConverter}}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
